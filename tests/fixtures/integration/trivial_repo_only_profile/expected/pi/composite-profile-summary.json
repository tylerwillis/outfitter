{
  "profileId": "repo-review",
  "agentId": "pi",
  "launchCommand": "pi",
  "launchArgs": [
    "--extension",
    "<composite-profile>/outfitter/outfitter-extension.js",
    "--model",
    "repo-review-model",
    "--repo-flag"
  ],
  "launchEnv": {
    "PI_CODING_AGENT_DIR": "<composite-profile>",
    "REPO_PROFILE": "enabled",
    "SHARED_LAYER": "repo-review"
  },
  "generatedProfile": {
    "id": "repo-review",
    "label": "Repository Review",
    "controls": {
      "model": "repo-review-model",
      "environment": {
        "REPO_PROFILE": "enabled",
        "SHARED_LAYER": "repo-review"
      },
      "args": ["--repo-flag"]
    }
  },
  "stateTargets": {
    "auth.json": "<home>/.pi/agent/auth.json",
    "settings.json": "<home>/.pi/agent/settings.json",
    "utilities": "<home>/.outfitter/cache/utilities"
  }
}
