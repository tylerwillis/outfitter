{
  "profileId": "engineering",
  "agentId": "pi",
  "launchCommand": "pi",
  "launchArgs": [
    "--model",
    "local-pi-model",
    "--provider",
    "team-provider",
    "--thinking",
    "high",
    "--prompt-template",
    "Review {{project.name}} with repository standards",
    "--system-prompt",
    "Supplemental engineering guardrails",
    "--extension",
    "personal-lint",
    "--skill",
    "code-review",
    "--pi-local-flag"
  ],
  "launchEnv": {
    "PI_CODING_AGENT_DIR": "<composite-profile>",
    "BASE_SHARED": "team-baseline",
    "LOCAL_ONLY": "enabled",
    "PI_ONLY": "enabled",
    "REMOTE_ONLY": "enabled",
    "REPO_ONLY": "enabled",
    "SHARED": "local",
    "SOURCE_ORDER": "local",
    "SUPPLEMENTAL_ONLY": "enabled",
    "TEAM_BASELINE": "enabled",
    "USER_ONLY": "enabled"
  },
  "generatedProfile": {
    "id": "engineering",
    "label": "Local Engineering Override",
    "controls": {
      "environment": {
        "SHARED": "local",
        "BASE_SHARED": "team-baseline",
        "TEAM_BASELINE": "enabled",
        "REMOTE_ONLY": "enabled",
        "SOURCE_ORDER": "local",
        "SUPPLEMENTAL_ONLY": "enabled",
        "USER_ONLY": "enabled",
        "REPO_ONLY": "enabled",
        "LOCAL_ONLY": "enabled"
      },
      "provider": "team-provider",
      "skills": ["code-review"],
      "model": "local-model",
      "args": ["--local-flag", "--remote-flag"],
      "systemPrompt": "Supplemental engineering guardrails",
      "system_prompt": "Supplemental engineering guardrails",
      "extensions": ["personal-lint"],
      "promptTemplate": "Review {{project.name}} with repository standards",
      "prompt_template": "Review {{project.name}} with repository standards",
      "thinking": "high",
      "pi": {
        "model": "local-pi-model",
        "environment": {
          "PI_ONLY": "enabled",
          "PI_SHARED": "local-pi"
        },
        "args": ["--pi-local-flag"]
      }
    }
  },
  "stateTargets": {
    "auth.json": "<home>/.pi/agent/auth.json",
    "settings.json": "<project>/.outfitter/local/profiles/engineering/cli_specific/pi/settings.json",
    "utilities": "<home>/.outfitter/cache/utilities"
  }
}
