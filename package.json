{
  "name": "@ai-outfitter/root",
  "private": true,
  "version": "0.7.1",
  "description": "Workspace root for Outfitter packages.",
  "type": "module",
  "workspaces": [
    "code/cli",
    "code/pi-extension"
  ],
  "scripts": {
    "build": "npm run build --workspace @ai-outfitter/outfitter",
    "prepare": "npm run build --workspace @ai-outfitter/outfitter",
    "dev_install": "npm run dev_install --workspace @ai-outfitter/outfitter",
    "docs:dev": "npm --prefix code/doc_site run dev --",
    "docs:build": "npm --prefix code/doc_site run build",
    "docs:start": "npm --prefix code/doc_site run start --",
    "docs:lint": "npm --prefix code/doc_site run lint",
    "docs:ci": "npm --prefix code/doc_site ci && npm run docs:lint && npm run docs:build",
    "typecheck": "npm run typecheck --workspace @ai-outfitter/outfitter",
    "lint": "npm run lint --workspace @ai-outfitter/outfitter",
    "lint:fix": "npm run lint:fix --workspace @ai-outfitter/outfitter",
    "test": "npm test --workspace @ai-outfitter/outfitter",
    "coverage": "npm run coverage --workspace @ai-outfitter/outfitter",
    "snapper:format": "node scripts/run-snapper.mjs --git-md -i",
    "check": "npm run snapper:format && prettier --write . && npm run lint:fix && npm run coverage",
    "check-ci": "prettier --check . && npm run lint && npm run coverage && npm run docs:ci"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
