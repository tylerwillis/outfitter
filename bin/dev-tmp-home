#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

DEFAULT_PROFILES_SOURCE="$REPO_ROOT/../outfitter-default-profiles"
[[ -d "$DEFAULT_PROFILES_SOURCE" ]] || {
  echo "error: could not find outfitter-default-profiles at $DEFAULT_PROFILES_SOURCE" >&2
  exit 1
}

DEV_HOME="$(mktemp -d -t outfitter-dev-home.XXXXXX)"

cleanup() {
  [[ -n "${DEV_HOME:-}" && -d "$DEV_HOME" ]] && rm -rf -- "$DEV_HOME"
}
trap cleanup EXIT

mkdir -p "$DEV_HOME/.pi/agent"

if [[ -f "${HOME:-}/.pi/agent/auth.json" ]]; then
  install -m 600 "$HOME/.pi/agent/auth.json" "$DEV_HOME/.pi/agent/auth.json"
fi

npm --prefix "$REPO_ROOT" run build

echo "Outfitter dev HOME: $DEV_HOME"
HOME="$DEV_HOME" node "$REPO_ROOT/dist/cli.js" setup "$DEFAULT_PROFILES_SOURCE"
